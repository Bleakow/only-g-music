# === Monorepo Only G — .gitignore raíz ===
# Patrones sin ancla inicial (/) para que apliquen en apps/*, packages/*, services/*.

# dependencies
node_modules/
.pnp
.pnp.*

# builds / caches
.next/
out/
build/
dist/
.turbo/

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables (secrets — never commit)
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# os / editor
.DS_Store
.idea/

# Imágenes placeholder / fotos de terceros en public/hero (copyright) — NO subir.
# Se conserva solo el fondo de marca que usa el Hero.
apps/only-g-web/public/hero/*
!apps/only-g-web/public/hero/hero-key-background.jpg

# Claude Code: ajustes locales de la máquina (no compartir)
.claude/settings.local.json
