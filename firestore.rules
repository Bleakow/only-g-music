rules_version = '2';

// Reglas de seguridad de Firestore para Only G Music.
// Desplegar con: firebase deploy --only firestore:rules
// (o pegar en Consola Firebase → Firestore → Reglas).
service cloud.firestore {
  match /databases/{database}/documents {

    // ¿El usuario actual tiene rol admin? (lee su doc de usuario). El rol `ceo`
    // HEREDA admin: es la super-cuenta del negocio (⊇ admin), así que pasa todos
    // los gates de admin. Por convención un CEO se aprovisiona con ['admin','ceo'],
    // pero incluir 'ceo' aquí lo hace robusto aunque el doc solo trajera 'ceo'.
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'ceo']);
    }

    // ¿El usuario actual es CEO? Gatea la config comercial INTERNA (comisiones) y
    // la escritura de precios. El rol `ceo` NO se otorga desde el cliente ni desde
    // el panel admin (adminSetRoles lo excluye): solo se asigna en consola.
    function isCeo() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['ceo']);
    }

    // ¿El slug de perfil dado EXISTE y pertenece al usuario actual? Para atribuir
    // un beat a un perfil (`beatmakerSlug`) hay que ser su DUEÑO: se valida contra
    // artistProfiles/{slug}.uid — NO contra el puntero users/{uid}.artistSlug, que
    // el cliente puede falsear libremente (así un beatmaker no puede firmar/enlazar
    // su beat con el perfil de OTRO artista).
    function ownsProfileSlug(slug) {
      return exists(/databases/$(database)/documents/artistProfiles/$(slug))
        && get(/databases/$(database)/documents/artistProfiles/$(slug)).data.uid == request.auth.uid;
    }

    // ── Config de la compañía (destino de pago, etc.) ────────────────
    // Lectura para autenticados (el pagador ve a dónde pagar); escritura admin.
    // Docs: config/payments.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Config comercial (partida por VISIBILIDAD de lectura) ────────
    // Firestore gatea la lectura a nivel de DOC, así que el config vive en dos
    // documentos separados, no en uno solo:
    //   - `comercialConfig/comisiones` → INTERNAS (comisionBeat, comisionProductor).
    //     Solo el CEO lee/escribe: son el margen de la empresa, no las ve nadie más.
    //   - `comercialConfig/precios` → precioBeat/precioMembresia/precioPerfil.
    //     Legibles por cualquier AUTENTICADO (el comprador debe VER lo que se le
    //     cobrará, para que display == cobro), pero solo el CEO los escribe.
    // El SERVIDOR (Cloud Functions, Admin SDK) lee AMBOS ignorando estas reglas,
    // con FALLBACK a las constantes del dominio (`getComercial`), así que NO hace
    // falta sembrar los docs: si no existen, rige el default.
    match /comercialConfig/comisiones {
      allow read: if isCeo();
      allow write: if isCeo();
    }
    match /comercialConfig/precios {
      allow read: if request.auth != null;
      allow write: if isCeo();
    }
    // Analítica: solo el ID de propiedad GA4 (para enlazar a los informes). Interno.
    match /comercialConfig/analitica {
      allow read: if isCeo();
      allow write: if isCeo();
    }

    // ── Sedes/estudios (override editable: dirección, horario, pago) ──
    // Lectura para autenticados; el admin edita el override. La semilla base
    // vive en código; aquí solo se guardan los campos que el admin cambia.
    match /sedes/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Cuentas de usuario ───────────────────────────────────────────
    // Cada quien lee/escribe SU propio documento. Los `roles` NO se pueden
    // auto-asignar ni escalar desde el cliente: al crear, deben ser
    // exactamente ['cliente']; al actualizar, deben quedar IGUAL que antes.
    // Cambiar roles (p. ej. dar 'productor' o 'admin') solo se hace vía
    // Admin SDK / Cloud Functions, que ignoran estas reglas.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.roles is list
        && request.resource.data.roles.size() == 1
        && request.resource.data.roles[0] == 'cliente';

      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.roles == resource.data.roles;

      allow delete: if false;

      // Notificaciones del usuario (campanita). Las CREA el servidor (Admin SDK /
      // Cloud Functions, vía el seam `notify`); el dueño solo LEE y marca
      // leído/archivado. Nunca crea ni borra desde el cliente.
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['leido', 'archivado']);
        allow create, delete: if false;
      }

      // Tokens FCM de cada dispositivo del usuario (para el push). El dueño los
      // gestiona; las Functions los leen vía Admin SDK.
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Datos de pago del socio (a dónde le paga Only G) ─────────────
    // Doc PRIVADO y dedicado `datosPago/{uid}` (id = uid). Frontera clave: el
    // admin LEE para poder pagar; el DUEÑO ESCRIBE sus propios datos (banco /
    // Nequi / efectivo). Va en doc aparte —no inline en users— porque el admin
    // no puede leer el `users` de otro; este doc sí permite "dueño escribe,
    // admin lee". NO gatea por rol: un usuario aún 'cliente' con convenio
    // pendiente puede dejarlos listos. `hasOnly` = allowlist de campos top-level
    // (el rol CEO futuro heredará el gate de isAdmin(); no hace falta tocarlo).
    match /datosPago/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.metodo in ['banco', 'nequi', 'efectivo']
        && request.resource.data.keys().hasOnly(['metodo', 'banco', 'nequi', 'efectivo', 'updatedAt']);
    }

    // ── Solicitudes de convenio (productor/beatmaker) ────────────────
    // El usuario crea SU propia solicitud (estado inicial 'pendiente') y lee las
    // suyas; el admin lee todas. La APROBACIÓN otorga un rol → va por Cloud
    // Function (Admin SDK), nunca desde el cliente: por eso update/delete = false.
    match /convenioRequests/{id} {
      allow read: if request.auth != null
        && (isAdmin() || resource.data.uid == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente'
        && (request.resource.data.tipo == 'productor'
          || request.resource.data.tipo == 'beatmaker');

      allow update, delete: if false;
    }

    // ── Beats (marketplace) ──────────────────────────────────────────
    // Los beats ACTIVOS son catálogo público; los inactivos solo los ve su dueño
    // o el admin. Publica/edita/borra el dueño (beatmakerUid propio) con rol
    // 'beatmaker'; el slug de atribución debe ser el suyo (evita firmar el beat
    // con el perfil de otro artista). El admin puede todo.
    match /beats/{id} {
      allow read: if resource.data.activo == true
        || isAdmin()
        || (request.auth != null && resource.data.beatmakerUid == request.auth.uid);

      allow create: if isAdmin()
        || (request.auth != null
          && request.resource.data.beatmakerUid == request.auth.uid
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['beatmaker'])
          && (!('beatmakerSlug' in request.resource.data)
            || request.resource.data.beatmakerSlug == null
            || ownsProfileSlug(request.resource.data.beatmakerSlug))
          // `masterPath`, si viene, debe vivir en la carpeta PRIVADA del propio
          // beatmaker (defensa en profundidad: confirmarPagoBeat firma esta
          // ruta server-side; sin esto, un beatmaker podría apuntar al máster
          // de otro y hacer que el servidor se lo firme — IDOR).
          && (!('masterPath' in request.resource.data)
            || request.resource.data.masterPath == null
            || request.resource.data.masterPath.matches('beats/masters/' + request.auth.uid + '/.*')));

      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.beatmakerUid == request.auth.uid
          && request.resource.data.beatmakerUid == resource.data.beatmakerUid
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['beatmaker'])
          && (!('masterPath' in request.resource.data)
            || request.resource.data.masterPath == null
            || request.resource.data.masterPath.matches('beats/masters/' + request.auth.uid + '/.*'))
          // beatmakerSlug: si NO cambia, se deja pasar (no re-valida ni bloquea si
          // el perfil se borró luego); si CAMBIA, el nuevo slug debe ser un perfil
          // propio — cierra la impersonación de atribución también por update.
          && (request.resource.data.beatmakerSlug == resource.data.beatmakerSlug
            || !('beatmakerSlug' in request.resource.data)
            || request.resource.data.beatmakerSlug == null
            || ownsProfileSlug(request.resource.data.beatmakerSlug)));

      allow delete: if isAdmin()
        || (request.auth != null && resource.data.beatmakerUid == request.auth.uid);
    }

    // ── Ventas de beats ──────────────────────────────────────────────
    // Las CREA el servidor (confirmPayment) vía Admin SDK. El comprador lee las
    // suyas; el beatmaker las suyas; el admin todas. Nadie escribe desde cliente.
    match /beatSales/{id} {
      // Lee el admin y el BEATMAKER (su venta). El COMPRADOR NO: el doc congela
      // `comision`/`neto` (la comisión INTERNA de Only G y lo que gana el
      // beatmaker), que el comprador no debe ver. Su historial de compra, cuando
      // se construya, saldrá de una fuente buyer-safe (el chat de pago en el que
      // ya participa), no de aquí. (listMisCompras no está cableado a UI aún.)
      allow read: if request.auth != null
        && (isAdmin()
          || resource.data.beatmakerUid == request.auth.uid);
      allow write: if false;
    }

    // ── Payouts (cuentas por pagar a socios: NETO por venta) ─────────
    // PASIVO por persona: lo que Only G le debe a un socio (beatmaker/productor)
    // por el neto de una venta. Los CREA el servidor (confirmarPagoBeat /
    // backfillPayouts) vía Admin SDK. El admin los lee TODOS (panel + balance);
    // el ACREEDOR lee solo los SUYOS. Nadie escribe desde el cliente: la
    // liquidación (Fase 3) pasará por Cloud Function.
    match /payouts/{id} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.acreedorUid == request.auth.uid);
      allow write: if false;
    }

    // ── Peticiones de beat a medida ──────────────────────────────────
    // El cliente crea SU petición (estado 'abierta'); la ven él, cualquier
    // beatmaker (para tomarla) y el admin. Un beatmaker con rol la TOMA
    // (abierta→tomada, tomadaPor propio) sin cambiar dueño ni descripción.
    match /beatRequests/{id} {
      // Lectura: admin, el dueño y el beatmaker que la tomó siempre. Las
      // peticiones ABIERTAS las ve cualquier BEATMAKER (para tomarlas) — NO
      // cualquier autenticado: el doc contiene PII del cliente (nombre, idea y
      // URL de referencia con token), así que el listado abierto se gatea por rol.
      allow read: if request.auth != null
        && (isAdmin()
          || resource.data.uid == request.auth.uid
          || resource.data.tomadaPor == request.auth.uid
          || (resource.data.estado == 'abierta'
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['beatmaker'])));

      // Crear: el cliente crea SU propia petición (estado inicial 'abierta').
      // Allowlist de campos + createdAt forzado a request.time: así nadie falsea
      // el orden de la cola ni pre-asigna 'tomadaPor' (fuera del allowlist).
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'abierta'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(
          ['uid', 'clientName', 'descripcion', 'genero', 'ejemploUrl', 'estado', 'createdAt']);

      // Tomar: un beatmaker pasa abierta → tomada fijándose como tomadaPor.
      // hasOnly congela el resto del documento (es un doc de OTRO usuario): solo
      // puede tocar estado y tomadaPor, no la URL de referencia ni los metadatos.
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.estado == 'abierta'
          && request.resource.data.estado == 'tomada'
          && request.resource.data.tomadaPor == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.descripcion == resource.data.descripcion
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'tomadaPor'])
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['beatmaker']));

      // Borrar: admin siempre; el dueño solo mientras siga ABIERTA (no puede
      // destruir una petición ya TOMADA por un beatmaker). No hay ruta de borrado
      // en la app: esto solo cierra el vector de vandalismo vía SDK crudo.
      allow delete: if isAdmin()
        || (request.auth != null
          && resource.data.uid == request.auth.uid
          && resource.data.estado == 'abierta');
    }

    // ── Solicitudes de cotización ────────────────────────────────────
    // El cliente crea SU propia solicitud (estado inicial 'pendiente') y solo
    // puede leer las suyas. El estudio responde/actualiza vía Admin SDK
    // (Cloud Functions), que ignora estas reglas.
    match /quotes/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pendiente';

      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);

      // El estudio (admin) responde/cambia el estado. El cliente DUEÑO solo puede
      // aceptar/rechazar su propuesta (cotizada → aceptada/rechazada), sin tocar
      // nada más (ni el precio propuesto): el monto es server-authoritative.
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'cotizada'
          && request.resource.data.status in ['aceptada', 'rechazada']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if false;
    }

    // ── Reservas ─────────────────────────────────────────────────────
    // El cliente crea SU reserva (estado inicial 'pendiente_pago') y solo puede
    // avanzarla a 'pago_en_revision' (subir comprobante). El resto de las
    // transiciones (confirmar, en_curso, completar…) y la asignación del monto
    // son server-authoritative vía Admin SDK / ruta protegida por rol.
    match /bookings/{id} {
      // `productorId` es SERVER/ADMIN-authoritative (asignación interna): el cliente
      // NO puede sembrarlo al crear. Si lo hiciera, al confirmarse la reserva se le
      // fabricaría una sesión + un pasivo (payout) a un UID arbitrario. (El reparto
      // de ingreso NO vive en el booking — el P&L lo deriva del payout — así que no
      // hay campo financiero cliente-legible/escribible que blindar aquí.)
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente_pago'
        && !('productorId' in request.resource.data);

      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);

      // Admin: cualquier transición. Cliente: solo pendiente_pago → pago_en_revision,
      // sin tocar `productorId` (debe quedar como estaba — el cliente no lo introduce
      // ni lo altera en su única transición permitida).
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && resource.data.estado == 'pendiente_pago'
          && request.resource.data.estado == 'pago_en_revision'
          && request.resource.data.get('productorId', '') == resource.data.get('productorId', ''));

      allow delete: if false;
    }

    // ── Pedidos (compra directa multi-servicio) ──────────────────────
    // Un pedido agrupa varias reservas (sus líneas) con UN pago. El cliente lo
    // crea en 'pendiente_pago'; sus reservas viven en `bookings` (reglas de
    // arriba). El cliente dueño solo puede enlazar la conversación de pago y
    // subir el comprobante (pendiente_pago → pago_en_revision), sin tocar
    // uid/total/lineas. Confirmar el pago (y con él todas las reservas) es
    // server-authoritative vía la Cloud Function confirmPayment.
    match /pedidos/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente_pago';

      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);

      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.uid == request.auth.uid
          && resource.data.estado == 'pendiente_pago'
          && request.resource.data.estado in ['pendiente_pago', 'pago_en_revision']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['estado', 'comprobanteUrl', 'paymentConversationId']));

      allow delete: if false;
    }

    // (El chat de cada solicitud migró al modelo `conversations` — ver más abajo.
    // Las subcolecciones `messages` bajo quotes/bookings quedaron obsoletas.)

    // ── Perfiles de artista (vitrina pública) ────────────────────────
    // Lectura PÚBLICA (sin sesión): hace falta para QR, compartir enlace y SEO.
    // El nombre real / fecha de nacimiento NO viven aquí (son privados en
    // users/{uid}). El DUEÑO (su users/{uid}.artistSlug == slug) puede construir
    // su perfil como BORRADOR sin necesitar todavía el rol 'artista' — así arma
    // su página antes de que el estudio active el rol/premium. NUNCA toca
    // uid/slug/puntos/premium (eso lo maneja admin/Functions). `published` es la
    // intención del artista; la visibilidad real exige published + premium.
    match /artistProfiles/{slug} {
      allow read: if true;

      // Solo crea EL slug que le pertenece (su users/{uid}.artistSlug), no el de
      // otro. premium arranca null y puntos en 0; orden/featured (curaduría) son
      // solo de admin. Admin puede crear cualquiera.
      allow create: if isAdmin()
        || (request.auth != null
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistSlug == slug
          && request.resource.data.puntos == 0
          && request.resource.data.premium == null
          && !request.resource.data.keys().hasAny(['orden', 'featured', 'disciplines', 'socio']));

      // El dueño edita su contenido, sin tocar campos sensibles ni la curaduría
      // de la vitrina (orden/featured = solo admin).
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.uid == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['uid', 'slug', 'puntos', 'premium', 'createdAt', 'orden', 'featured',
                       'disciplines', 'socio']));

      allow delete: if isAdmin();

      // Likes: un doc por usuario, solo el suyo (el conteo se deriva del tamaño).
      match /likes/{uid} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // ── Productores (vitrina pública del home) ───────────────────────
    // Contenido CURADO por el admin que se muestra como secciones del scroll del
    // home. Lectura PÚBLICA (sin sesión, igual que los perfiles). Escritura solo
    // admin: ni dueño ni slug — son contenido del sello, no de un usuario.
    match /producers/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Sesiones (consola del productor — PROYECCIÓN sin finanzas) ───
    // No contiene `amount`: el productor ve a quién atiende y cuándo, nunca el
    // cobro. La lee el admin, el productor asignado o el cliente dueño. La crea
    // el admin (14a); en 14b la derivará una Cloud Function. El productor solo
    // cambia estado/tiempos de SU sesión, nada estructural.
    match /sessions/{id} {
      allow read: if isAdmin()
        || (request.auth != null
          && (resource.data.productorId == request.auth.uid
            || resource.data.uid == request.auth.uid));

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.productorId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['reservaId', 'productorId', 'uid', 'serviceName', 'sede',
                       'scheduledStart', 'scheduledEnd', 'createdAt']));

      allow delete: if isAdmin();
    }

    // ── Slots tomados (proyección pública de reservas) ───────────────
    // Lo leen todos los autenticados (para pintar la disponibilidad). La
    // escritura ocurre en la transacción de reserva. MVP: write autenticado;
    // se endurece en la fase de Route Handlers (server-authoritative).
    match /daySlots/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Disponibilidad del productor ─────────────────────────────────
    // La leen todos los autenticados (los clientes la necesitan para ver qué
    // horas hay libres). Solo la escribe quien tenga rol 'productor' o 'admin'
    // (se comprueba leyendo su documento de usuario).
    match /availability/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['productor', 'admin']);
    }

    // ── Conversaciones (chat generalizado: soporte / pago / directo) ─
    // conversations/{id}: la leen sus participantes (o admin). Un usuario puede
    // CREAR una conversación en la que él participa (p. ej. abrir un chat de
    // pago), con estado inicial 'abierto'. Las transiciones de estado/pago, el
    // cierre del hilo y el `lastMessage` son server-authoritative (Admin SDK /
    // Cloud Functions, que ignoran estas reglas). En el Slice C se permitirá al
    // cliente la transición acotada metodo_pendiente → comprobante_pendiente.
    match /conversations/{id} {
      // `resource == null` permite el `get` de un id inexistente (para el
      // get-or-create del chat de soporte); no filtra nada de las existentes.
      allow read: if isAdmin()
        || (request.auth != null
          && (resource == null
            || resource.data.participants.hasAny([request.auth.uid])));

      allow create: if isAdmin()
        || (request.auth != null
          && request.resource.data.status == 'abierto'
          // Un chat de pago no puede nacer ya 'confirmado' (el premium solo lo
          // activa la Cloud Function confirmPayment). Además, el creador debe
          // ser el ÚNICO participante (no basta con `hasAny`): así
          // `confirmPayment` puede confiar en `participants[0]` como el
          // pagador REAL y no un uid ajeno metido por el cliente (spoofing).
          && (request.resource.data.type == 'pago'
            ? (request.resource.data.participants == [request.auth.uid]
              && request.resource.data.pago.estado in ['metodo_pendiente', 'comprobante_pendiente'])
            // No-pago (soporte/directo): el creador debe ir en participants, y el
            // hilo se limita a 2 como MÁXIMO. Ningún hilo creado por el cliente
            // supera 2 (soporte nace con [dueño]; directo con [cliente, otro]); el
            // admin/estudio se añade por Admin SDK (ignora reglas). El tope evita
            // que un solo create+mensaje abanique notificaciones/push a N uids
            // arbitrarios (el trigger onConversationMessage avisa a cada participante).
            : (request.resource.data.participants.hasAny([request.auth.uid])
              && request.resource.data.participants.size() <= 2)));

      // El admin (vía Function) hace cualquier transición. El participante solo
      // puede mover el pago de comprobante_pendiente → en_revision (al subir el
      // comprobante), sin tocar concepto/monto/método ni cerrar el hilo.
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.participants.hasAny([request.auth.uid])
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['pago', 'status', 'updatedAt'])
          && resource.data.status == 'abierto'
          && request.resource.data.status == 'esperando_confirmacion'
          && resource.data.pago.estado == 'comprobante_pendiente'
          && request.resource.data.pago.estado == 'en_revision'
          && request.resource.data.pago.concepto == resource.data.pago.concepto
          && request.resource.data.pago.monto == resource.data.pago.monto
          && request.resource.data.pago.metodo == resource.data.pago.metodo);

      allow delete: if false;

      // Mensajes: los leen los participantes; un participante crea SUS propios
      // mensajes (from == su uid) de tipo 'mensaje'/'comprobante', y solo si el
      // hilo está 'abierto'. Los mensajes 'estado'/'metodo'/'pago_confirmado' y
      // los del 'sistema' van por Admin SDK. Inmutables.
      match /messages/{mid} {
        allow read: if isAdmin()
          || (request.auth != null
            && get(/databases/$(database)/documents/conversations/$(id)).data.participants.hasAny([request.auth.uid]));
        allow create: if isAdmin()
          || (request.auth != null
            && get(/databases/$(database)/documents/conversations/$(id)).data.participants.hasAny([request.auth.uid])
            && get(/databases/$(database)/documents/conversations/$(id)).data.status == 'abierto'
            && request.resource.data.from == request.auth.uid
            && request.resource.data.tipo in ['mensaje', 'comprobante']);
        allow update, delete: if false;
      }
    }

    // ── Transacciones (libro de ingresos: premium, etc.) ────────────
    // Solo el admin las lee (panel de finanzas). Los asientos los escribe el
    // servidor (Cloud Function confirmPayment); el cliente nunca escribe.
    match /transactions/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Activos / bienes (módulo contable — Fase 16a) ────────────────
    // Inventario de activos fijos (PP&E). TODO admin-only: respeta el invariante
    // de que el productor NUNCA ve finanzas/bienes. Append-only: no se borra
    // (delete = false); dar de baja es un update que marca bajaAt/bajaMotivo.
    // `createdBy` queda atado al admin que lo crea (auditoría).
    match /activos/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Movimientos / gastos (módulo contable — Fase 16b) ────────────
    // Gastos manuales del Estado de Resultados. TODO admin-only (el productor
    // NUNCA ve finanzas). Append-only: no se borra (delete = false); anular es
    // un update que marca anuladoAt/anuladoMotivo. `createdBy` = el admin creador.
    match /movimientos/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Pasivos (módulo contable — Fase 16c) ─────────────────────────
    // Deudas/obligaciones del Balance General. TODO admin-only. Append-only:
    // no se borra (delete = false); liquidar es un update (saldadoAt). El
    // Patrimonio se DERIVA (Activos − Pasivos): no es una colección.
    match /pasivos/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Logs de errores (observabilidad — Fase 4.4) ─────────────────
    // Cualquier autenticado registra SUS errores (el cliente limita y deduplica);
    // solo el admin los lee. Append-only.
    match /errorLogs/{id} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ── G Notes (biblioteca del escritor) ────────────────────────────
    // Un doc por usuario con SU biblioteca de composición (canciones, releases,
    // listas): gnotes/{uid}. Contenido PRIVADO del autor — solo él lee/escribe;
    // ni el admin lo ve (son sus letras). No gatea por rol: el acceso al producto
    // lo controla la app (LoginGate); el entitlement de membresía llega en M7.
    match /gnotes/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Por defecto, todo lo demás cerrado hasta que su fase defina reglas.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
