rules_version = '2';

// Reglas de seguridad de Cloud Storage para Only G Music.
// Desplegar con: firebase deploy --only storage
// (o pegar en Consola Firebase → Storage → Reglas).
service firebase.storage {
  match /b/{bucket}/o {

    // Subidas del usuario (adjuntos de cotización, etc.): cada quien escribe
    // y lee SOLO bajo su propia carpeta. Límite de 25 MB por archivo.
    match /uploads/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 25 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Máster de un beat (marketplace): ruta PRIVADA. El beatmaker dueño sube el
    // archivo completo; NADIE lo lee desde el cliente (ni siquiera su dueño): se
    // entrega al comprador por URL firmada, generada por el servidor (Admin SDK,
    // `confirmarPagoBeat`) tras confirmar el pago.
    match /beats/masters/{uid}/{allPaths=**} {
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 100 * 1024 * 1024;
      allow read: if false;
    }

    // Todo lo demás cerrado hasta que su fase lo defina.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
