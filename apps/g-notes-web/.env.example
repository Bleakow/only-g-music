# ── Firebase (cliente) ────────────────────────────────────────────
# MISMOS valores que apps/only-g-web/.env.local: G Notes apunta al mismo proyecto
# Firebase, así el `uid` y la cuenta son los mismos en ambas apps.
# Son valores PÚBLICOS (se exponen en el navegador). La seguridad real son las
# reglas de Firestore y la verificación del ID token en el servidor.
# El PROJECT_ID lo usa además el servidor para verificar los tokens (admin.ts).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Enlace a la app hermana ───────────────────────────────────────
# URL de Only G Music (para el enlace de "crear cuenta"). Si no se define, usa
# la URL de producción por defecto.
NEXT_PUBLIC_ONLY_G_URL=

# ── IA (servidor) ─────────────────────────────────────────────────
# SECRETO: nunca lleva prefijo NEXT_PUBLIC_ (se filtraría al navegador).
# En producción va como secreto de App Hosting, no en este archivo.
GEMINI_API_KEY=

# Modelos por defecto (opcional). Override de los que trae el código.
GNOTES_GEMINI_MODEL=
GNOTES_GEMINI_CREATIVE_MODEL=
