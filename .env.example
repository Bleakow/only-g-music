# ── Firebase (cliente) ────────────────────────────────────────────
# Copia este archivo a `.env.local` y rellena con los valores del objeto
# `firebaseConfig` (Consola Firebase → Project settings → Your apps → Web).
# Son valores PÚBLICOS (se exponen en el navegador). La seguridad real está
# en las reglas de Firestore/Storage, no en ocultar estas claves.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── SEO ───────────────────────────────────────────────────────────
# Origen público del sitio (sin barra final). Para canonical/hreflang/sitemap.
# Ej: https://onlyg.example  · Si no se define, usa http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
